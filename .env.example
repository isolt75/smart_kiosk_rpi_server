# Smart Drive-through Edge Server - Environment Variables
# 실제 운영 환경에서는 이 파일을 .env로 복사하여 값을 채워 사용한다.

# === Device ===
EDGE_DEVICE_ID=edge-001

# === Main Server ===
EDGE_API_BASE_URL=https://main-server.example.com/api/v1
EDGE_API_KEY=replace-with-your-api-key
# 또는 JWT 토큰. 둘 중 하나만 설정해도 됨 (Bearer 우선)
EDGE_API_JWT=

# TLS 자체 서명 인증서 사용 시 CA 번들 경로 (없으면 공란)
EDGE_CA_BUNDLE=

# === Sensor (HC-SR04) ===
EDGE_SENSOR_TRIG_PIN=23
EDGE_SENSOR_ECHO_PIN=24
EDGE_SENSOR_POLL_INTERVAL_MS=50
EDGE_SENSOR_MAX_DISTANCE_M=4.0
EDGE_SENSOR_MOVING_AVG_WINDOW=5
EDGE_SENSOR_OUTLIER_DELTA_M=0.5
EDGE_SENSOR_DETECT_THRESHOLD_M=1.5
EDGE_SENSOR_DEPART_THRESHOLD_M=2.0
EDGE_SENSOR_DETECT_CONSECUTIVE=3
EDGE_SENSOR_HYSTERESIS_M=0.1
EDGE_SENSOR_COOLDOWN_SEC=10

# === Camera ===
EDGE_CAMERA_WIDTH=1920
EDGE_CAMERA_HEIGHT=1080
EDGE_CAMERA_JPEG_QUALITY=90

# === Microphone ===
EDGE_AUDIO_SAMPLE_RATE=16000
EDGE_AUDIO_CHANNELS=1
EDGE_AUDIO_FRAME_DURATION_MS=30
EDGE_AUDIO_MAX_DURATION_SEC=30
EDGE_AUDIO_VAD_SILENCE_SEC=2.0
EDGE_AUDIO_VAD_AGGRESSIVENESS=2

# === Cache ===
EDGE_CACHE_BASE_DIR=/var/lib/edge/cache
EDGE_CACHE_MAX_BYTES=1073741824
EDGE_CACHE_MAX_AGE_HOURS=24

# === Networking ===
EDGE_HTTP_CONNECT_TIMEOUT=5
EDGE_HTTP_READ_TIMEOUT=30
EDGE_QUEUE_MAX_SIZE=100
EDGE_HTTP_MAX_WORKERS=4
EDGE_RETRY_MAX_ATTEMPTS=5
EDGE_RETRY_INITIAL_DELAY=1
EDGE_RETRY_MAX_DELAY=16

# === Heartbeat ===
EDGE_HEARTBEAT_INTERVAL_SEC=60

# === Logging ===
EDGE_LOG_DIR=/var/log/edge-server
EDGE_LOG_LEVEL=INFO

# === Status LEDs (옵션, 사용 안 하면 -1) ===
EDGE_LED_GREEN_PIN=17
EDGE_LED_YELLOW_PIN=27
EDGE_LED_RED_PIN=22
